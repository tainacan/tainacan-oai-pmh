{
    "name": "tainacan/tainacan-oai-pmh",
    "description": "OAI-PMH provider and importer for Tainacan with caching, monitoring, and validation.",
    "type": "wordpress-plugin",
    "license": "GPL-3.0-or-later",
    "minimum-stability": "stable",
    "require": {
        "php": ">=8.1"
    },
    "require-dev": {
        "wp-coding-standards/wpcs": "^3.1",
        "phpcompatibility/phpcompatibility-wp": "^2.1",
        "phpcsstandards/phpcsextra": "^1.2",
        "phpcsstandards/phpcsutils": "^1.0",
        "automattic/vipwpcs": "^3.0",
        "squizlabs/php_codesniffer": "^3.10",
        "phpunit/phpunit": "^9.6",
        "yoast/phpunit-polyfills": "^2.0",
        "wp-cli/wp-cli-bundle": "^2.11"
    },
    "scripts": {
        "lint": "phpcs --standard=phpcs.xml.dist",
        "lint:fix": "phpcbf --standard=phpcs.xml.dist",
        "test": "phpunit",
        "compat": "phpcs --standard=PHPCompatibilityWP --runtime-set testVersion 8.1- ."
    },
    "config": {
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true
        },
        "platform-check": false,
        "sort-packages": true
    }
}
